{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "회의실 예약 조회",
      "weight": "Bolder",
      "size": "Large"
    },
    {
      "type": "TextBlock",
      "text": "날짜와 시간을 선택하여 빈 회의실을 조회하세요.",
      "wrap": true,
      "spacing": "Small"
    },
    {
      "type": "Input.Date",
      "id": "date",
      "label": "날짜",
      "isRequired": true,
      "errorMessage": "날짜를 선택해주세요."
    },
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "Input.ChoiceSet",
              "id": "startTime",
              "label": "시작 시간",
              "isRequired": true,
              "errorMessage": "시작 시간을 선택해주세요.",
              "choices": [
                { "title": "08:00", "value": "08:00" },
                { "title": "08:30", "value": "08:30" },
                { "title": "09:00", "value": "09:00" },
                { "title": "09:30", "value": "09:30" },
                { "title": "10:00", "value": "10:00" },
                { "title": "10:30", "value": "10:30" },
                { "title": "11:00", "value": "11:00" },
                { "title": "11:30", "value": "11:30" },
                { "title": "12:00", "value": "12:00" },
                { "title": "12:30", "value": "12:30" },
                { "title": "13:00", "value": "13:00" },
                { "title": "13:30", "value": "13:30" },
                { "title": "14:00", "value": "14:00" },
                { "title": "14:30", "value": "14:30" },
                { "title": "15:00", "value": "15:00" },
                { "title": "15:30", "value": "15:30" },
                { "title": "16:00", "value": "16:00" },
                { "title": "16:30", "value": "16:30" },
                { "title": "17:00", "value": "17:00" },
                { "title": "17:30", "value": "17:30" },
                { "title": "18:00", "value": "18:00" }
              ]
            }
          ]
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "Input.ChoiceSet",
              "id": "endTime",
              "label": "종료 시간",
              "isRequired": true,
              "errorMessage": "종료 시간을 선택해주세요.",
              "choices": [
                { "title": "08:30", "value": "08:30" },
                { "title": "09:00", "value": "09:00" },
                { "title": "09:30", "value": "09:30" },
                { "title": "10:00", "value": "10:00" },
                { "title": "10:30", "value": "10:30" },
                { "title": "11:00", "value": "11:00" },
                { "title": "11:30", "value": "11:30" },
                { "title": "12:00", "value": "12:00" },
                { "title": "12:30", "value": "12:30" },
                { "title": "13:00", "value": "13:00" },
                { "title": "13:30", "value": "13:30" },
                { "title": "14:00", "value": "14:00" },
                { "title": "14:30", "value": "14:30" },
                { "title": "15:00", "value": "15:00" },
                { "title": "15:30", "value": "15:30" },
                { "title": "16:00", "value": "16:00" },
                { "title": "16:30", "value": "16:30" },
                { "title": "17:00", "value": "17:00" },
                { "title": "17:30", "value": "17:30" },
                { "title": "18:00", "value": "18:00" },
                { "title": "18:30", "value": "18:30" },
                { "title": "19:00", "value": "19:00" }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Input.ChoiceSet",
      "id": "floor",
      "label": "층",
      "value": "all",
      "choices": [
        { "title": "전체", "value": "all" },
        { "title": "2층", "value": "2" },
        { "title": "7층", "value": "7" },
        { "title": "8층", "value": "8" }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "조회하기",
      "data": {
        "action": "searchRooms"
      }
    }
  ]
}
